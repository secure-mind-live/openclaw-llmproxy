    },
    "use_ollama_via_proxy": {
      "provider": "openai-compatible",
      "base_url": "http://localhost:8005/v1",
      "api_key": "your-proxy-api-key",
      "model": "llama3.2:1b"
    },
    "use_openclaw_gateway_via_proxy": {

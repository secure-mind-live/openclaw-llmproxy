[Unit]
Description=OpenClaw LLM Proxy
After=network.target ollama.service

[Service]
Type=simple
User=openclaw
WorkingDirectory=/opt/openclaw-llmproxy
ExecStart=/opt/openclaw-llmproxy/venv/bin/uvicorn proxy.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PROXY_API_KEY=changeme
Environment=RATE_LIMIT_RPM=60
Environment=MAX_REQUEST_SIZE_MB=10

[Install]
WantedBy=multi-user.target
